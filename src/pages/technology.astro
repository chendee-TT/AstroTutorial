---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Technology | Tactonic Technologies">

  <!-- =========================
  HERO / OVERVIEW
  ========================== -->
  <section class="border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-24 lg:py-32">

      <div class="max-w-4xl">

        <p class="text-sm font-semibold tracking-[0.2em] uppercase text-gray-500">
          Sensing Platform Technology
        </p>

        <h1 class="mt-6 text-5xl md:text-6xl font-bold tracking-tight text-gray-900 leading-tight">
          High-resolution sensing for real-time physical interaction understanding.
        </h1>

        <p class="mt-8 text-xl text-gray-600 leading-8">
          Tactonic Technologies develops solid-state multi-axis force sensing systems designed to measure and interpret complex physical contact dynamics in real time.
        </p>

        <p class="mt-6 text-lg text-gray-600 leading-8">
          These systems enable machines to transition from simple force detection to structured understanding of interaction, including contact geometry, pressure distribution, and shear dynamics.
        </p>

      </div>

    </div>
  </section>

  <!-- =========================
  CORE PLATFORM PRINCIPLES
  ========================== -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">

      <h2 class="text-sm uppercase tracking-[0.2em] text-gray-500">
        Platform Principles
      </h2>

      <p class="mt-4 text-4xl font-bold text-gray-900 max-w-3xl">
        From force measurement to physical interaction understanding.
      </p>

      <div class="mt-16 grid md:grid-cols-3 gap-8">

        <div class="border border-gray-200 rounded-2xl p-8">
          <h3 class="text-xl font-semibold text-gray-900">
            Multi-Axis Sensing
          </h3>
          <p class="mt-4 text-gray-600 leading-7">
            Captures force, pressure, and shear components across multiple degrees of freedom to represent complex contact events.
          </p>
        </div>

        <div class="border border-gray-200 rounded-2xl p-8">
          <h3 class="text-xl font-semibold text-gray-900">
            Real-Time Response
          </h3>
          <p class="mt-4 text-gray-600 leading-7">
            Designed for continuous feedback during dynamic physical interaction, enabling responsive system adaptation.
          </p>
        </div>

        <div class="border border-gray-200 rounded-2xl p-8">
          <h3 class="text-xl font-semibold text-gray-900">
            Interaction Modeling
          </h3>
          <p class="mt-4 text-gray-600 leading-7">
            Moves beyond raw force detection toward structured interpretation of contact behavior and surface dynamics.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- =========================
  CURRENT PLATFORM (3 DOF)
  ========================== -->
  <section class="bg-gray-50 border-y border-gray-200 py-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="max-w-3xl">
        <h2 class="text-sm uppercase tracking-[0.2em] text-gray-500">
          Current Platform
        </h2>

        <p class="mt-4 text-4xl font-bold text-gray-900">
          3 DOF solid-state sensing architecture
        </p>

        <p class="mt-6 text-lg text-gray-600 leading-8">
          The current generation platform provides high-resolution measurement of multi-axis force and pressure interactions, enabling real-time feedback during physical contact events.
        </p>
      </div>

      <div class="mt-12 grid md:grid-cols-2 gap-8">

        <div class="bg-white border border-gray-200 rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-gray-900">
            Contact Measurement
          </h3>
          <p class="mt-4 text-gray-600">
            Captures distributed force profiles across contact surfaces for improved understanding of interaction geometry.
          </p>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-gray-900">
            Shear-Aware Response
          </h3>
          <p class="mt-4 text-gray-600">
            Detects directional force components to support more stable and adaptive physical interaction.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- =========================
  NEXT GENERATION (6 DOF)
  ========================== -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="max-w-3xl">
        <h2 class="text-sm uppercase tracking-[0.2em] text-gray-500">
          Next Generation
        </h2>

        <p class="mt-4 text-4xl font-bold text-gray-900">
          Expanded 6 DOF interaction sensing
        </p>

        <p class="mt-6 text-lg text-gray-600 leading-8">
          The next generation platform extends sensing resolution and dimensionality to support richer modeling of physical interaction dynamics, enabling higher fidelity interpretation of complex contact environments.
        </p>
      </div>

      <div class="mt-12 grid md:grid-cols-3 gap-8">

        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-semibold text-gray-900">
            Spatial Resolution
          </h3>
        </div>

        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-semibold text-gray-900">
            Dynamic Adaptation
          </h3>
        </div>

        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-semibold text-gray-900">
            Interaction Fidelity
          </h3>
        </div>

      </div>

    </div>
  </section>

  <!-- =========================
  SYSTEM VIEW (ABSTRACT)
  ========================== -->
  <section class="bg-gray-900 text-white py-24">
    <div class="max-w-7xl mx-auto px-6">

      <div class="max-w-3xl">
        <h2 class="text-sm uppercase tracking-[0.2em] text-gray-400">
          System Perspective
        </h2>

        <p class="mt-4 text-4xl font-bold">
          From sensing to physical understanding.
        </p>

        <p class="mt-8 text-lg text-gray-300 leading-8">
          Tactonic systems are designed to serve as the interface between physical contact and machine-level interpretation of interaction dynamics, enabling new classes of responsive and adaptive systems.
        </p>
      </div>

    </div>
  </section>

</MainLayout>