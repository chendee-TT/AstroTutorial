---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="TACTONIC">
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-bold leading-tight max-w-4xl">
        Adaptive Robotic Gripping Through Advanced Shape Sensing
      </h1>

      <p class="mt-8 text-xl text-gray-600 max-w-3xl">
        Tactonic develops next-generation sensing systems for robotic grippers,
        enabling real-time shape detection and dynamic grip adaptation for
        complex manipulation tasks.
      </p>

      <div class="mt-10 flex gap-4">
        <a
          href="/technology"
          class="bg-black text-white px-6 py-3 rounded-lg"
        >
          Explore Technology
        </a>

        <a
          href="/partnerships"
          class="border border-gray-300 px-6 py-3 rounded-lg"
        >
          Partnerships
        </a>
      </div>
    </div>
  </section>
</MainLayout>