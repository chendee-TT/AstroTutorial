        <div class="font-bold text-xl">TACTONIC</div>

        <div class="flex gap-6 text-sm">
          <a href="/">Home</a>
          <a href="/technology">Technology</a>
          <a href="/applications">Applications</a>
          <a href="/partnerships">Partnerships</a>
          <a href="/about">About</a>
